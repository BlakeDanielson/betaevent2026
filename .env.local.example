# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# In Vercel: add all of these under Project → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Get this after running: stripe listen --forward-to localhost:3000/api/webhook
# In production, create a webhook endpoint in the Stripe dashboard pointing to:
#   https://your-domain.com/api/webhook
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Stripe Price IDs ──────────────────────────────────────────────────────────
# Create products + prices in your Stripe dashboard (or they'll be created
# dynamically from config.ts — this is optional if using price_data in code).
# STRIPE_PRICE_GENERAL_ADMISSION=price_REPLACE_ME
# STRIPE_PRICE_VIP=price_REPLACE_ME

# ── Resend (email confirmations) ──────────────────────────────────────────────
# Get from https://resend.com/api-keys
# Verify your domain at https://resend.com/domains
# Leave empty to skip email confirmations.
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=events@yourdomain.com

# ── Google Sheets Logging (optional) ─────────────────────────────────────────
# Deploy the Apps Script in README.md as a web app and paste its URL here.
# Leave empty to skip Google Sheets logging.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# ── Debug / Testing ───────────────────────────────────────────────────────────
# A random secret used to protect /api/debug/test-email.
# Generate one with: openssl rand -hex 24
# Leave empty to DISABLE the test endpoint entirely.
DEBUG_TEST_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
